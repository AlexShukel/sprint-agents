{
	"name": "sprint-agents",
	"version": "0.1.0",
	"description": "Universal Claude agent orchestration for autonomous software development",
	"type": "module",
	"bin": {
		"sprint-agents": "./dist/bin/cli.js"
	},
	"scripts": {
		"build": "tsc",
		"dev": "tsc --watch",
		"web": "vite --config web/vite.config.ts web",
		"web:build": "vite build --config web/vite.config.ts web",
		"web:preview": "vite preview --config web/vite.config.ts web",
		"prepublishOnly": "npm run build"
	},
	"files": [
		"dist/",
		"templates/"
	],
	"keywords": [
		"claude",
		"ai",
		"agents",
		"orchestration",
		"code-generation"
	],
	"license": "MIT",
	"engines": {
		"node": ">=20.0.0"
	},
	"devDependencies": {
		"@types/node": "^22.0.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.1.4",
		"typescript": "^5.7.0",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"react": "^19.2.4",
		"react-dom": "^19.2.4"
	}
}
